# =============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# =============================================================================

# S3 bucket for Terraform remote state storage
# This bucket must exist before running deploy.sh
# Terraform 1.10+ uses native S3 locking (no DynamoDB table needed)
export TF_STATE_BUCKET='my-terraform-state-bucket'

# =============================================================================
# REGION CONFIGURATION (CRITICAL!)
# =============================================================================
# All regions must match! Set all three to ensure consistency:

# 1. AWS Region for resource deployment
# MUST match the region where your VPC and subnets exist
export AWS_REGION='us-west-2'

# 2. AWS Region for the S3 state bucket (usually same as AWS_REGION)
export TF_STATE_REGION='us-west-2'

# 3. ALSO update your AWS CLI config to match:
#    aws configure set region us-west-2
#
# Why all three?
# - AWS_REGION: Terraform uses this
# - TF_STATE_REGION: For S3 backend configuration
# - AWS CLI config: Used during terraform init before variables load
#
# Region mismatch will cause "VPC not found" errors!

# =============================================================================
# AZURE DEVOPS CREDENTIALS (required with --update-ado-secret and --auto-approve)
# =============================================================================

# export ADO_PAT='your-personal-access-token'
# export ADO_ORG_URL='https://dev.azure.com/your-org'

# Alternative: Terraform variable for application layer apply only
# export TF_VAR_ado_pat_value='your-personal-access-token'

# =============================================================================
# OPTIONAL ENVIRONMENT VARIABLES
# =============================================================================

# AWS Profile (if using named profiles)
# export AWS_PROFILE='my-profile'

# Disable ANSI colors in deploy.sh log output
# export NO_COLOR=1

# =============================================================================
# USAGE
# =============================================================================
# 1. Copy this file to .env (do not commit .env to version control)
#    cp .env.example .env
#
# 2. Edit .env with your actual values
#
# 3. Load environment variables
#    source .env
#
# 4. Run deployment (interactive: prompts for ADO credentials if needed)
#    ./deploy.sh deploy --update-ado-secret
#
# 5. CI/CD non-interactive example:
#    export ADO_PAT='...'
#    export ADO_ORG_URL='https://dev.azure.com/your-org'
#    ./deploy.sh deploy --auto-approve --with-config-layer --update-ado-secret
# =============================================================================
