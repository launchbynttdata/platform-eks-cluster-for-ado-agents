# Base Infrastructure Layer Configuration
#
# Copy this file to terraform.tfvars and customize the values for your environment.
# Required values are marked with comments.

# AWS Configuration
aws_region = "us-west-2"

# Cluster Configuration (REQUIRED)
cluster_name    = "ado-agent-cluster"  # Must be unique in your AWS account
cluster_version = "1.33"

# Networking Configuration (REQUIRED)
# These values must be provided - no defaults
vpc_id = "vpc-xxxxxxxxx"        # Replace with your VPC ID
subnet_ids = [                  # Replace with your private subnet IDs (minimum 2)
  "subnet-xxxxxxxxx",
  "subnet-yyyyyyyyy"
]

# Security Configuration
endpoint_public_access = false   # Keep false for production
public_access_cidrs   = ["10.0.0.0/16"]  # Restrict to your VPC CIDR

# IAM Configuration
create_iam_roles = true  # Set to false if using existing roles

# KMS Configuration
create_kms_key                  = true
kms_key_description             = "EKS Cluster encryption key for ado-agent-cluster"
kms_key_deletion_window_in_days = 7

# Fargate Configuration
# Default selectors for middleware and application namespaces
fargate_profile_selectors = [
  {
    namespace = "keda-system"
  },
  {
    namespace = "external-secrets-system"
  },
  {
    namespace = "ado-agents"
  }
]

fargate_system_profile_selectors = [
  {
    namespace = "kube-system"
    labels = {
      "k8s-app" = "kube-dns"
    }
  }
]

# EKS Add-ons
eks_addons = {
  "coredns" = {
    version = "v1.11.1-eksbuild.9"
  }
  "kube-proxy" = {
    version = "v1.33.0-eksbuild.1"
  }
  "vpc-cni" = {
    version = "v1.18.3-eksbuild.1"
  }
}

# VPC Endpoints
create_vpc_endpoints = true
vpc_endpoint_services = [
  "s3",
  "ecr_dkr",
  "ecr_api",
  "ec2",
  "logs",
  "monitoring", 
  "sts",
  "secretsmanager"
]

# Exclude conflicting VPC endpoints if they already exist
exclude_vpc_endpoint_services = []

# EC2 Node Groups (optional - leave empty if using only Fargate)
ec2_node_group = {
  # Uncomment to enable EC2 nodes for workloads that can't run on Fargate
  # "buildkit-nodes" = {
  #   instance_types = ["t3.medium", "t3.large"]
  #   disk_size      = 100
  #   ami_type       = "AL2_x86_64"
  #   capacity_type  = "ON_DEMAND"
  #   desired_size   = 1
  #   max_size       = 5
  #   min_size       = 0
  #   labels = {
  #     "workload-type" = "buildkit"
  #   }
  #   taints = [
  #     {
  #       key    = "workload-type"
  #       value  = "buildkit"
  #       effect = "NO_SCHEDULE"
  #     }
  #   ]
  # }
}

# Cluster Autoscaler (enable if using EC2 node groups)
enable_cluster_autoscaler     = false
cluster_autoscaler_namespace  = "kube-system"

# Tagging
environment = "dev"
project     = "ado-agent-cluster"

tags = {
  "ProjectId"     = "MVITMR"
  "Environment"   = "dev"
  "Owner"         = "platform-team"
  "CostCenter"    = "engineering"
  "ManagedBy"     = "terraform"
  "Layer"         = "base-infrastructure"
}